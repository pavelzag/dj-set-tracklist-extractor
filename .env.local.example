# RapidAPI key for Shazam — get it at https://rapidapi.com/apidojo/api/shazam
# Subscribe to the "Basic" (free) plan: 500 requests/month
RAPIDAPI_KEY=your_rapidapi_key_here

# yt-dlp cookie auth — needed to bypass YouTube bot detection
# Local dev: use YTDLP_COOKIES_BROWSER (chrome | firefox | safari)
# Docker/Cloud Run: export cookies with yt-dlp --cookies-from-browser chrome cookies.txt
#   then mount and set YTDLP_COOKIES_FILE=/app/cookies.txt
YTDLP_COOKIES_BROWSER=chrome
